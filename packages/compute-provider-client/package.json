{
  "name": "@cmux/compute-provider-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/client/index.ts",
  "types": "./src/client/index.ts",
  "scripts": {
    "typecheck": "bunx tsgo --noEmit -p tsconfig.json",
    "generate": "bun run scripts/generate-openapi-client.ts"
  },
  "exports": {
    ".": {
      "import": "./src/client/index.ts",
      "types": "./src/client/index.ts"
    },
    "./client": {
      "import": "./src/client/client/index.ts",
      "types": "./src/client/client/index.ts"
    },
    "./client.gen": {
      "import": "./src/client/client.gen.ts",
      "types": "./src/client/client.gen.ts"
    }
  },
  "devDependencies": {
    "@cmux/compute-provider": "workspace:*",
    "@hey-api/openapi-ts": "^0.82.1",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  }
}
